{
  "TdsProxy": {
    "Listeners": [
      {
        "Name": "IRBManager",
        "ListenOnPort": 1433,
        "ForwardToHost": "db3",
        "ForwardToPort": 1433,
        "SslCertificate": {
          "Source": "File",
          "FilePath": "certificate.pfx",
          "Password": ""
        },
        "Authenticators": [
          {
            "Name": "IRBManager",
            "Dll": "IRBManager.TDSProxy.Authenticator.dll",
            "Class": "IRBManager.TDSProxy.Authenticator.Authenticator"
          }
        ]
      }
    ]
  },
  "AppSettings": {
    "IRBSecurityConnectionString": "data source=DB3;initial catalog=IRBSecurity;User ID=IRBSecurity;password=IRBSecurity",
    "AllowNonContextConnections": "true"
  }
}
